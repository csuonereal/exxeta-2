# --- REMOTE API KEYS (HYBRID PROCESSING) ---
# Provide AT LEAST ONE of these keys to enable Remote Proprietary routing.
# If none are provided, the system falls back to your local Ollama models.

# OPENAI_API_KEY=sk-your-openai-api-key-here
# GEMINI_API_KEY=sk-your-gemini-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-claude-key-here


# --- LOCAL OLLAMA CONFIGURATION (PRIVACY ENGINE) ---
OLLAMA_HOST=http://localhost:11434

# Ensure you have pulled these models locally (e.g. `ollama pull llama3`)
# Change these if you want to use a smaller/faster model like 'phi3'
OLLAMA_SRD_MODEL=llama3
OLLAMA_JUDGE_MODEL=llama3
OLLAMA_ROUTING_MODEL=llama3


# --- SYSTEM CONFIGURATION ---
DEBUG=True
# DATABASE_URL=sqlite:///./compliance_middleware.db
